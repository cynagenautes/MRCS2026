{
    "name": "texlive",
    "build": {
    "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": "false",
            "installOhMyZsh": "false",
            "installOhMyZshConfig" : "false",
            "upgradePackages": "false",
            "username": "texlive",
            "userUid": "1000",
            "userGid": "1000"
        },
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {}
    },
    "runArgs": [
        "--rm"
    ],
    "mounts": [
        {
            "target": "${containerWorkspaceFolder}/build",
            "type": "volume"
        }
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "James-Yu.latex-workshop",
                "mosapride.zenkaku",
                "sohamkamani.code-eol",
                "oderwat.indent-rainbow"
            ]
        }
    },
    "postStartCommand": "sudo chown -R texlive:texlive ${containerWorkspaceFolder}/build",
    "containerUser": "root",
    "remoteUser": "texlive"
}
