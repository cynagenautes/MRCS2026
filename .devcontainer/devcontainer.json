{
    "name": "LaTeX (TeX Live)",
    "build": {
    "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": "false",
            "installOhMyZsh": "false",
            "installOhMyZshConfig" : "false",
            "upgradePackages": "false",
            "username": "texlive",
            "userUid": "1000",
            "userGid": "1000"
        },
        // MCPサーバーのためにnpxが必要
        "ghcr.io/devcontainers/features/node:1": {},
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {},
        "ghcr.io/rails/devcontainer/features/bun": {}
    },
    "runArgs": [
        "--rm"
    ],
    "mounts": [
        {
            "target": "${containerWorkspaceFolder}/build",
            "type": "volume"
        },
        // 以下 Claude Codeのためのバインドマウント
        {   "source": "${localEnv:HOME}/.claude",
            "target": "/home/texlive/.claude",
            "type": "bind"
        },
        {   "source": "${localEnv:HOME}/.claude.json",
            "target": "/home/texlive/.claude.json",
            "type": "bind"
        },
        {   "source": "${localEnv:HOME}/.config/ccstatusline",
            "target": "/home/texlive/.config/ccstatusline",
            "type": "bind"
        }
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "James-Yu.latex-workshop",
                "mosapride.zenkaku",
                "sohamkamani.code-eol",
                "oderwat.indent-rainbow",
                "shardulm94.trailing-spaces",
                "Anthropic.claude-code"
            ]
        }
    },
    "postStartCommand": "sudo chown -R texlive:texlive ${containerWorkspaceFolder}/build",
    "containerUser": "root",
    "remoteUser": "texlive"
}
